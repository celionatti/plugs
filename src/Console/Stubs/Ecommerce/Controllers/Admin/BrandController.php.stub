<?php

declare(strict_types=1);

namespace Modules\{{name}}\Controllers\Admin;

use Plugs\Base\Controller\Controller;
use Plugs\Http\Request;
use Psr\Http\Message\ResponseInterface;
use Modules\{{name}}\Models\Brand;
use Plugs\Utils\Str;

class BrandController extends Controller
{
    public function index(): ResponseInterface
    {
        $brands = Brand::all();
        return $this->view('{{lowerName}}::admin/brands/index', [
            'brands' => $brands
        ]);
    }

    public function store(Request $request): ResponseInterface
    {
        $data = $request->all();
        $data['slug'] = Str::slug($data['name']);

        Brand::create($data);

        return $this->redirect('/admin/{{lowerName}}/brands')->withSuccess('Brand added successfully.');
    }

    public function delete(string $id): ResponseInterface
    {
        $brand = Brand::find((int) $id);
        if ($brand) {
            $brand->delete();
        }

        return $this->redirect('/admin/{{lowerName}}/brands')->withSuccess('Brand deleted successfully.');
    }
}
