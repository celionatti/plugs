<!DOCTYPE html>
<html lang="en" class="h-full">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <yield:title default="Auth" /> | {{ config('app.name', 'Plugs') }}
    </title>
    @plugcss
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary-color: {{ \App\Models\Setting::getValue('primary_color', '#6366f1') }};
            --secondary-color: {{ \App\Models\Setting::getValue('secondary_color', '#a855f7') }};
        }

        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .font-outfit { font-family: 'Outfit', sans-serif; }

        .mesh-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            background-color: #020617;
            background-image: 
                radial-gradient(circle at 0% 0%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 100% 0%, rgba(168, 85, 247, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 0% 100%, rgba(99, 102, 241, 0.15) 0%, transparent 50%);
            filter: blur(100px);
            animation: mesh-pulse 10s ease-in-out infinite alternate;
        }

        @keyframes mesh-pulse {
            from { transform: scale(1); opacity: 0.8; }
            to { transform: scale(1.1); opacity: 1; }
        }

        .glass-panel {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .premium-text-gradient {
            background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.7) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        ::-webkit-scrollbar { width: 0px; background: transparent; }
        * { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
    <stack:styles />
</head>

<body class="bg-slate-950 text-slate-100 h-screen overflow-hidden relative">
    <!-- Global Full-Screen Mesh Background -->
    <div class="mesh-bg fixed inset-0 z-0"></div>

    <div class="flex h-full w-full relative z-10 overflow-hidden">

        <!-- Visual Section (Left) -->
        <div class="hidden lg:flex lg:w-1/2 relative items-center justify-center overflow-hidden">
            <div class="relative z-10 p-16 w-full max-w-2xl">
                <div
                    class="mb-10 inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-gradient-to-tr from-indigo-500 to-purple-500 shadow-2xl shadow-indigo-500/20">
                    <i class="bi bi-shield-lock-fill text-3xl text-white"></i>
                </div>
                <h1 class="text-6xl font-black tracking-tight font-outfit text-white mb-6 leading-none">
                    Security <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">Simplified.</span>
                </h1>
                <p class="text-xl text-slate-300/80 font-medium leading-relaxed max-w-lg">
                    Experience the next generation of authentication. Secure, sleek, and optimized for high-performance
                    workflows.
                </p>

                <!-- Status Indicators -->
                <div
                    class="mt-12 flex items-center gap-8 text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400/60">
                    <span class="flex items-center gap-2"><span
                            class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></span>
                        Systems Active</span>
                    <span class="flex items-center gap-2"><i class="bi bi-shield-check text-indigo-400"></i> Encrypted
                        Mode</span>
                </div>
            </div>
        </div>

        <!-- Form Section (Right) -->
        <div class="w-full lg:w-1/2 flex items-center justify-center p-3 sm:p-6 lg:p-5">
            <!-- Inset Rounded Panel -->
            <div
                class="glass-panel w-full lg:h-full max-w-xl lg:max-w-none flex flex-col items-center justify-center relative p-6 sm:p-10 lg:p-12 rounded-[2rem] lg:rounded-[3rem] overflow-y-auto custom-scrollbar shadow-2xl">

                <div class="w-full max-w-md relative z-10 transition-all duration-500">
                    <!-- Branding for Mobile -->
                    <div class="lg:hidden mb-6 text-center">
                        <div
                            class="inline-flex items-center justify-center w-11 h-11 rounded-2xl bg-gradient-to-tr from-indigo-500 to-purple-500 mb-4 shadow-lg shadow-indigo-500/20">
                            <i class="bi bi-shield-lock-fill text-xl text-white"></i>
                        </div>
                    </div>

                    <div class="mb-8 text-left">
                        <h2 class="text-3xl font-extrabold tracking-tight font-outfit text-white mb-1.5">
                            <yield:heading />
                        </h2>
                        <p class="text-[14px] text-slate-400 font-medium leading-relaxed">
                            <yield:subheading />
                        </p>
                    </div>

                    <main-content class="w-full" flash />

                    <!-- Integrated Footer -->
                    @if(isset($__sections['footer']) && trim($__sections['footer']) !== '')
                    <div class="mt-8 pt-8 border-t border-white/5 text-center lg:text-left">
                        <yield:footer />
                    </div>
                    @endif
                </div>
            </div>
        </div>
    </div>

    <stack:scripts />
</body>

</html>
