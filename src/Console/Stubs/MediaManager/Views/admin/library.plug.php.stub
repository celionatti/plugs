                @foreach($mediaItems as $media)
                <div class="relative group aspect-square rounded-2xl overflow-hidden bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-800 cursor-pointer" 
                     onclick="viewMedia(this)"
