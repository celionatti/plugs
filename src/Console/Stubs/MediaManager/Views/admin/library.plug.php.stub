    </div>

    <!-- Media View Modal -->
    <div id="media-modal" class="fixed inset-0 z-[60] hidden flex items-center justify-center p-4">
        <div id="modal-backdrop" onclick="closeMediaModal()" class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm cursor-pointer"></div>
        <div class="relative bg-white dark:bg-slate-900 rounded-3xl w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col md:flex-row shadow-2xl scale-95 opacity-0 transition-all duration-300" id="{{lowerName}}-modal-content">
            <!-- Preview -->
            <div class="md:w-3/5 bg-slate-50 dark:bg-slate-950 flex items-center justify-center p-8 relative">
                <img id="modal-preview" src="" alt="" class="max-w-full max-h-full object-contain rounded-xl shadow-lg">
                <button onclick="closeMediaModal()" class="absolute top-4 left-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center backdrop-blur-md transition-all border border-white/10">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <!-- Details -->
            <div class="md:w-2/5 p-8 flex flex-col">
                <div class="mb-6">
                    <h3 id="modal-filename" class="text-lg font-bold text-slate-900 dark:text-white truncate">file_name.jpg</h3>
                    <p id="modal-meta" class="text-xs text-slate-500 font-medium mt-1 uppercase tracking-tight">JPEG • 1024 KB • 1920x1080</p>
                </div>

                <div class="flex-1 space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5">File URL</label>
                        <div class="flex gap-2">
                            <input type="text" id="modal-url" readonly class="flex-1 px-3 py-2 rounded-lg bg-slate-50 dark:bg-slate-800 border-none ring-1 ring-slate-200 dark:ring-slate-700 text-xs font-medium focus:ring-0">
                            <button onclick="copyModalUrl()" class="p-2 rounded-lg bg-indigo-600 text-white text-sm hover:scale-105 active:scale-95 transition-all">
                                <i class="bi bi-copy"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800 flex justify-between gap-3">
                    <button onclick="deleteMedia()" class="px-5 py-2.5 rounded-xl border border-rose-100 dark:border-rose-900/30 text-rose-500 text-xs font-bold hover:bg-rose-50 dark:hover:bg-rose-900/20 transition-all flex items-center gap-2">
                        <i class="bi bi-trash3-fill"></i>
                        Delete Asset
                    </button>
                    <button onclick="saveMediaInfo()" class="px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-xs font-bold hover:scale-105 active:scale-95 transition-all">
                        Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <slot:scripts>
    @verbatim
    <script>
        window.activeMediaId = null;
        
        window.handleMediaUpload = async function(e) {
            const files = e.target.files;
            if(!files.length) return;
            
            const formData = new FormData();
            for(let file of files) {
                formData.append('files[]', file);
            }
            
            const uploadTrigger = document.getElementById('upload-trigger');
            if (uploadTrigger) {
                uploadTrigger.disabled = true;
                uploadTrigger.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Uploading...';
            }
            
            try {
                const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
                const response = await fetch('/admin/{{lowerName}}/upload', {
                    method: 'POST',
                    headers: {
                        'X-CSRF-TOKEN': csrfToken,
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                });
                
                const data = await response.json();
                if(data.success) {
                    window.location.reload();
                } else {
                    alert('Upload failed');
                }
            } catch (error) {
                alert('Upload failed: ' + error.message);
            } finally {
                if (uploadTrigger) {
                    uploadTrigger.disabled = false;
                    uploadTrigger.innerHTML = '<i class="bi bi-cloud-arrow-up-fill text-lg"></i> Upload Files';
                }
            }
        };

        window.viewMedia = function(element) {
            window.activeMediaId = element.dataset.id;
            
            const isImage = element.dataset.isImage === '1';
            const modalPreview = document.getElementById('modal-preview');
            const modalFilename = document.getElementById('modal-filename');
            const modalMeta = document.getElementById('modal-meta');
            const modalUrl = document.getElementById('modal-url');
            
            if (isImage) {
                modalPreview.src = element.dataset.url;
                modalPreview.classList.remove('hidden');
            } else {
                modalPreview.src = '';
                modalPreview.classList.add('hidden');
            }
            
            modalFilename.textContent = element.dataset.filename;
            modalMeta.textContent = `${element.dataset.mime} • ${element.dataset.size}`;
            modalUrl.value = element.dataset.url;

            const modal = document.getElementById('media-modal');
            const modalContent = document.getElementById('{{lowerName}}-modal-content');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modalContent.classList.remove('scale-95', 'opacity-0');
                modalContent.classList.add('scale-100', 'opacity-100');
            }, 10);
        };
        
        window.closeMediaModal = function() {
            const modal = document.getElementById('media-modal');
            const modalContent = document.getElementById('{{lowerName}}-modal-content');
            modalContent.classList.add('scale-95', 'opacity-0');
            modalContent.classList.remove('scale-100', 'opacity-100');
            setTimeout(() => modal.classList.add('hidden'), 300);
            window.activeMediaId = null;
        };

        window.deleteMedia = async function() {
            if(!confirm('Delete this asset permanently?')) return;
            
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
            
            try {
                const response = await fetch(`/admin/{{lowerName}}/${window.activeMediaId}`, { 
                    method: 'DELETE',
                    headers: {
                        'X-CSRF-TOKEN': csrfToken,
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                
                const data = await response.json();
                if(data.success) {
                    window.location.reload();
                } else {
                    alert('Delete failed');
                }
            } catch (error) {
                alert('Delete failed: ' + error.message);
            }
        };

        window.copyModalUrl = function() {
            const urlInput = document.getElementById('modal-url');
            urlInput.select();
            document.execCommand('copy');
            alert('Copied to clipboard!');
        };
    </script>
    @endverbatim
    </slot:scripts>
</layout>
