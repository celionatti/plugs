                    @else
                        <div class="w-full h-full flex items-center justify-center">
                            <i class="bi bi-file-earmark-text text-3xl text-slate-400"></i>
                        </div>
                    @endif
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-3">
                        <span class="text-white text-[10px] font-bold truncate">{{ $media->filename }}</span>
                        <span class="text-slate-300 text-[8px] font-medium">{{ $media->getFormattedSize() }}</span>
                    </div>
                </div>
                @endforeach
                
                @if(empty($mediaItems))
                <div class="col-span-full h-full flex flex-col items-center justify-center text-center p-12">
                    <div class="w-20 h-20 rounded-full bg-slate-50 dark:bg-slate-800 flex items-center justify-center mb-4">
                        <i class="bi bi-images text-4xl text-slate-300"></i>
