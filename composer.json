{
  "name": "plugs/plugs",
  "description": "Plugs is a modern, lightweight PHP framework by Amisu Usman (Celio Natti) - built for developers who crave speed, structure, and freedom. Its modular design and intuitive syntax make web development faster, cleaner, and more connected - your power source for smart PHP projects. ⚡",
  "type": "library",
  "license": "Apache-2.0",
  "autoload": {
    "psr-4": {
      "Plugs\\": "src/"
    },
    "files": [
      "src/functions/app.php",
      "src/functions/error.php",
      "src/functions/asset_helper.php",
      "src/functions/helper.php",
      "src/functions/route.php",
      "src/functions/redirect.php",
      "src/functions/http.php",
      "src/functions/dump.php",
      "src/functions/abort.php",
      "src/functions/ai.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "App\\": "app/",
      "Modules\\": "modules/",
      "Database\\": "database/",
      "Tests\\": "tests/"
    }
  },
  "keywords": [
    "framework",
    "php",
    "plugs",
    "mvc",
    "fast"
  ],
  "homepage": "https://github.com/celionatti/plugs",
  "support": {
    "issues": "https://github.com/celionatti/plugs/issues",
    "source": "https://github.com/celionatti/plugs"
  },
  "authors": [
    {
      "name": "Celio Natti",
      "email": "celionatti@gmail.com",
      "role": "Developer"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-pdo": "*",
    "clue/redis-react": "^2.8",
    "guzzlehttp/guzzle": "^7.10",
    "league/oauth2-google": "^5.0",
    "predis/predis": "^3.4",
    "psr/container": "^1.0",
    "psr/event-dispatcher": "^1.0",
    "psr/http-message": "^1.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "react/event-loop": "*",
    "react/http": "*",
    "react/socket": "*",
    "symfony/mailer": "^7.4",
    "vlucas/phpdotenv": "^5.6"
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "suggest": {
    "dompdf/dompdf": "Required to generate PDF documents (^3.1).",
    "predis/predis": "Required to use the Predis cache driver (^2.3)."
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "*",
    "phpstan/phpstan": "*",
    "phpunit/phpunit": "^11.0"
  }
}
